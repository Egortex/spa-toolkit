{
	"name": "@chepchik/spa-router",
	"version": "0.1.2",
	"description": "Lightweight client-side SPA router: link interception, History API, lazy-loaded pages, nested layouts, loaders, guards, caching, prefetch, scroll restoration and View Transitions.",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch"
	},
	"keywords": [
		"router",
		"spa",
		"history-api",
		"view-transitions"
	],
	"license": "MIT",
	"devDependencies": {
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vite-plugin-dts": "^5.0.2"
	}
}
