{
	"name": "@chepchik/bind-form",
	"version": "0.1.1",
	"description": "Tiny dependency-free form binding helper: submit handling, validation schema and error display.",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch"
	},
	"keywords": [
		"form",
		"validation",
		"spa"
	],
	"license": "MIT",
	"devDependencies": {
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vite-plugin-dts": "^5.0.2"
	}
}
