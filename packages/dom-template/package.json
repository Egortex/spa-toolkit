{
	"name": "@chepchik/dom-template",
	"version": "0.1.2",
	"description": "Tiny helper to mount an HTML string into the DOM and collect [ref] elements into a typed object.",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch"
	},
	"keywords": [
		"dom",
		"template",
		"spa"
	],
	"license": "MIT",
	"devDependencies": {
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vite-plugin-dts": "^5.0.2"
	}
}
